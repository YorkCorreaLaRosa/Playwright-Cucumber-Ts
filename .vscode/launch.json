{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Depurar Pruebas Playwright",
      "type": "node",
      "request": "launch",
      "program": "${workspaceRoot}/node_modules/@playwright/test/cli.js",
      "args": [
        "test"
      ],
      "console": "integratedTerminal",
      "sourceMaps": true,
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
